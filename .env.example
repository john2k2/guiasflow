# GuíasFlow - Project Configuration

# Site Configuration
SITE_URL=https://guiasflow.github.io
SITE_NAME=GuíasFlow
SITE_DESCRIPTION=Learn how to do anything step by step

# Languages Configuration
DEFAULT_LANGUAGE=es
SUPPORTED_LANGUAGES=es,en,pt,fr,de

# MiniMax API Configuration (set via environment variable)
# MINIMAX_API_KEY=your_api_key_here
MINIMAX_API_HOST=https://api.minimax.io

# Content Generation
GUIDES_PER_WEEK=3
TRANSLATIONS_ENABLED=true

# SEO Settings
SEO_HIGH_CPC_CATEGORIES=finanzas,tecnologia,salud,legal,educacion
SEO_TARGET_WORD_COUNT=1200

# AdSense
ADSENSE_PUBLISHER_ID=pub-XXXXXXXXXXXXXXXX

# GitHub Pages
DEPLOY_BRANCH=gh-pages
DEPLOY_DIR=src